# Supabase — obtén estos valores en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# URL pública del sitio (usado en sitemap y metadatos OG)
# Local: http://localhost:3000
# Producción: https://dysaglezco.github.io/bertina-store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ruta base para GitHub Pages (dejar vacío si el sitio está en la raíz del dominio)
# GitHub Pages con repo bertina-store: /bertina-store
NEXT_PUBLIC_BASE_PATH=
